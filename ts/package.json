{
  "name": "typescript-node-project",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build:example": "rm -rf dist && tsup examples/main.ts --format esm --minify",
    "watch": "tsup examples/main.ts --watch --format esm",
    "check": "tsc --build",
    "lint": "eslint examples/ tests/",
    "lint:fix": "eslint examples/ tests/ --fix",
    "test": "vitest run --test-timeout=15000",
    "test:watch": "vitest --test-timeout=15000",
    "gen:example": "cd examples/gen && cargo run --release -- --clean",
    "gen:tests": "cd tests/gen && cargo run --release -- --clean",
    "gen:all": "pnpm run -r gen:example & pnpm run -r gen:tests & wait"
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.7.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@mysten/sui": "^2.16.2",
    "commander": "^14.0.3",
    "tsup": "^8.5.1"
  }
}
